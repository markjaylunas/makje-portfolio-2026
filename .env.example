# Environment variables for local development and configuration

# Optional: The base URL of your server (e.g., http://localhost:3000)
SERVER_URL=

# URL for the Better Auth service (authentication provider)
BETTER_AUTH_URL=

# Secret key for Better Auth (keep this secure)
BETTER_AUTH_SECRET=

# Google OAuth client ID for sign-in
GOOGLE_CLIENT_ID=

# Google OAuth client secret
GOOGLE_CLIENT_SECRET=

# GitHub OAuth client ID (if used)
GITHUB_CLIENT_ID=

# Cloudflare account ID for deployment
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare database ID
CLOUDFLARE_DATABASE_ID=

# Cloudflare database access token
CLOUDFLARE_DATABASE_TOKEN=

# URL for R2 storage (Cloudflare R2 bucket)
R2_PUBLIC_URL=

# API key for Resend email service
RESEND_API_KEY=

# Email address to send notifications or emails to
RESEND_TO=

# Email address from which emails are sent
RESEND_FROM=