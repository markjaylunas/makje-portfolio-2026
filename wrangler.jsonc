{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "makje-portfolio-2026",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
   "d1_databases": [
        {
            "binding": "DB",
            "database_name": "makje-portfolio-2026",
            "database_id": "8a9d4c08-7a27-45f6-bec2-9e46f8c4e053",
            "migrations_dir": "src/db/migrations",
            "remote": true
        }
    ],
    "r2_buckets": [
        {
            "binding": "BUCKET",
            "bucket_name": "makje-portfolio-2026",
            "remote": true
        }
    ],
    "kv_namespaces": [
        {
            "binding": "RATE_LIMITER",
            "id": "bc841929f5f24f958e22c58010ce040a",
            "remote": true
        }
    ]
}
